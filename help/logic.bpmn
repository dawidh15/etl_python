    <bpmn:textAnnotation id="TextAnnotation_1ei8lq0">
      <bpmn:text>TableMetadata
str name
obj conn_string
array pk, array pk_type
array type1, array type1_type
array type2, array type2_type
array type3, array type3_type

read_json(path_jason, path_json_schema): table specs in json</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0gt818f" sourceRef="DataObjectReference_1pxbocg" targetRef="TextAnnotation_1ei8lq0" />
    <bpmn:textAnnotation id="TextAnnotation_1kckv31">
      <bpmn:text>ITable
TableMetadata table_metadata
obj data
dict t1_hashmap
dict t2_hashmap
dict t3_hashmap
IHash hasher
ICombiner combiner
---
set_haser(IHash new_hasher)
use_hasher(dict ph_col_dic)
set_combiner(ICombiner new_combiner)
use_combiner(...)

add_metadata(TableMetadata)
add_data(object)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0orltz5" sourceRef="DataObjectReference_173iswz" targetRef="TextAnnotation_1kckv31" />
    <bpmn:textAnnotation id="TextAnnotation_121dg7i">
      <bpmn:text>combine(obj data, array pk, array cols) -&gt; return dict (pk: combined_str)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1o2kukx" sourceRef="DataObjectReference_10i1nmo" targetRef="TextAnnotation_121dg7i" />
    <bpmn:textAnnotation id="TextAnnotation_14c1gxq">
      <bpmn:text>def combine(sparkDf, array pk, array cols)</bpmn:text>
