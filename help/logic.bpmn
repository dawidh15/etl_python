    <bpmn:textAnnotation id="TextAnnotation_01qncur">
      <bpmn:text>Return a dictionary with pk as keys and combined string value as values. One entry per record in a table</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0ku8q4y" sourceRef="Group_0bi8xa1" targetRef="TextAnnotation_01qncur" />
    <bpmn:textAnnotation id="TextAnnotation_0oqmewa">
      <bpmn:text>hash(dict)</bpmn:text>
    </bpmn:textAnnotation>
